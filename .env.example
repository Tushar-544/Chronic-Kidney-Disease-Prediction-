# --- BACKEND CONFIGURATION (Python/FastAPI) ---
# Toggle between 'ONNX' or 'KERAS' for different model testing
MODEL_TYPE="ONNX"
MODEL_PATH="./backend/models/best_final_model.onnx"

# The port your server runs on
BACKEND_PORT=8000


# --- FRONTEND CONFIGURATION (Vite/React) ---
# This tells React where the Python API is located
# (Vite requires variables to start with VITE_)
VITE_API_BASE_URL="http://localhost:8000"


# --- SYSTEM SETTINGS ---
# Set to 'development' for detailed error logging
ENV_MODE="development"
DEBUG=True
